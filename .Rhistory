library(Hmisc)
theme_fig1 <- function(){
theme_bw(base_size = 12) +
theme(
panel.grid = element_blank(),
legend.position = "top",
axis.text.x = element_text(angle = 45, hjust = 1),
strip.background = element_blank(),
strip.text = element_text(face = "bold")
)
}
# ==============================================================================
# FIGURE 1A - aboveground growth
# ==============================================================================
cat("\n[1/5] Processing agroundgrowth...\n")
df_ag <- read.delim(text = txt) %>%
mutate(Group = factor(ifelse(grepl("Control", Sample),
"Control", "SynCom"),
levels = c("Control","SynCom")))
df_ag_long <- df_ag %>%
pivot_longer(-c(Sample, Group),
names_to = "Key",
values_to = "Value") %>%
mutate(
Type = factor(substr(Key,1,1), levels = c("H","S","L")),
Day = factor(sub("^[A-Z]", "", Key),
levels = c("0","5","10","15","18"))
)
# ===============================
# 统计（修复版）
# ===============================
stat_1A <- df_ag_long %>%
group_by(Type, Day) %>%
t_test(Value ~ Group) %>%
adjust_pvalue("BH") %>%
add_significance("p.adj")
# ===============================
# 统计（修复版）
# ===============================
stat_1A <- df_ag_long %>%
group_by(Type, Day) %>%
t_test(Value ~ Group) %>%
adjust_pvalue(p.col = "p") %>%
add_significance("p.adj")
# 星号位置
star_pos <- df_ag_long %>%
group_by(Type, Day) %>%
summarise(y = max(Value), .groups = "drop") %>%
left_join(stat_1A, by = c("Type","Day"))
star_pos$y <- star_pos$y * 1.08
# ===============================
# 作图
# ===============================
p1A <- ggplot(df_ag_long, aes(Day, Value, fill = Group)) +
stat_summary(fun = mean, geom = "col",
position = position_dodge(0.8),
alpha = 0.4, width = 0.7) +
stat_summary(fun.data = mean_se, geom = "errorbar",
position = position_dodge(0.8), width = 0.2) +
geom_jitter(aes(color = Group),
position = position_jitterdodge(0.8),
size = 2, alpha = 0.6) +
geom_text(data = star_pos,
aes(x = Day, y = y, label = p.adj.signif),
inherit.aes = FALSE,
size = 4, color = "red") +
facet_wrap(~Type, scales = "free_y") +
theme_fig1()
