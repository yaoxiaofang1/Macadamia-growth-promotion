soil$Group <- ifelse(grepl("Control", soil$Sample), "Control", "SynCom")
soil_long <- soil %>%
pivot_longer(-c(Sample, Group),
names_to = "Index",
values_to = "Value")
stat_1D <- soil_long %>%
group_by(Index) %>%
t_test(Value ~ Group) %>%
adjust_pvalue("BH")
stat_1D <- soil_long %>%
group_by(Index) %>%
t_test(Value ~ Group) %>%
adjust_pvalue(method = "BH")
p1D <- ggplot(soil_long, aes(Group, Value, fill = Group)) +
stat_summary(fun = mean, geom = "col", alpha = 0.4) +
stat_summary(fun.data = mean_se, geom = "errorbar") +
geom_jitter(width = 0.15, size = 2) +
facet_wrap(~Index, scales = "free_y") +
theme_fig1()
# ==============================================================================
# FIGURE 1E - microbiome (genus level)
# ==============================================================================
micro_files <- read.delim(file.path(input_dir, "rootbac_genus.txt"), check.names = FALSE)
micro_long <- micro_files %>%
pivot_longer(-genus,
names_to = "Sample",
values_to = "Abundance") %>%
group_by(Sample) %>%
mutate(Abundance = Abundance / sum(Abundance) * 100) %>%   # 如果已是relative abundance可删
ungroup() %>%
mutate(Group = ifelse(grepl("Control", Sample), "Control", "SynCom")) %>%
filter(!grepl("^other", genus, ignore.case = TRUE))
stat_micro <- micro_long %>%
group_by(genus) %>%
summarise(
p = wilcox.test(Abundance ~ Group)$p.value,
mean_C = mean(Abundance[Group=="Control"]),
mean_S = mean(Abundance[Group=="SynCom"]),
.groups = "drop"
) %>%
mutate(p_adj = p.adjust(p, "BH"))
sig_micro <- stat_micro %>%
filter(p_adj < 0.05) %>%
arrange(p_adj) %>%
slice_head(n = 20)
plot_df <- micro_long %>%
filter(genus %in% sig_micro$genus)
stat_micro <- micro_long %>%
group_by(genus) %>%
summarise(
p = wilcox.test(Abundance ~ Group,
exact = FALSE,
correct = TRUE)$p.value,
mean_C = mean(Abundance[Group=="Control"]),
mean_S = mean(Abundance[Group=="SynCom"]),
.groups = "drop"
) %>%
mutate(p_adj = p.adjust(p, "BH"))
sig_micro <- stat_micro %>%
filter(p_adj < 0.05) %>%
arrange(p_adj) %>%
slice_head(n = 20)
plot_df <- micro_long %>%
filter(genus %in% sig_micro$genus)
p1E <- ggplot(plot_df, aes(genus, Abundance, fill = Group)) +
geom_boxplot(alpha = 0.4, outlier.shape = NA) +
geom_jitter(width = 0.2, size = 2) +
theme_fig1()
# ==============================================================================
# FIGURE 1G/H - metabolomics
# ==============================================================================
met <- read.delim(file.path(input_dir, "metabolism_sig647.txt"), row.names = 1)
group <- ifelse(grepl("Control", rownames(met)), "Control", "SynCom")
met_stats <- data.frame(
metabolite = colnames(met),
mean_C = colMeans(met[group=="Control", ]),
mean_S = colMeans(met[group=="SynCom", ])
)
met_stats$log2FC <- log2((met_stats$mean_S + 1e-10)/(met_stats$mean_C + 1e-10))
met_stats$p <- sapply(1:ncol(met), function(i){
t.test(met[group=="Control", i], met[group=="SynCom", i])$p.value
})
met_stats$p_adj <- p.adjust(met_stats$p, "BH")
met_stats$group <- case_when(
met_stats$p_adj < 0.05 & met_stats$log2FC > 1 ~ "Up",
met_stats$p_adj < 0.05 & met_stats$log2FC < -1 ~ "Down",
TRUE ~ "NS"
)
p1G <- ggplot(met_stats, aes(log2FC, -log10(p_adj), color = group)) +
geom_point(alpha = 0.6) +
geom_vline(xintercept = c(-1,1), linetype="dashed") +
theme_fig1()
top20_met <- met_stats %>%
arrange(p_adj) %>%
slice_head(n = 20)
p1H <- ggplot(top20_met,
aes(x = reorder(metabolite, log2FC),
y = log2FC,
fill = log2FC > 0)) +
geom_col() +
coord_flip() +
theme_fig1()
# ==============================================================================
# CORRELATION HEATMAP
# ==============================================================================
bac <- read.delim(file.path(input_dir, "rootbac_genus_sig20.txt"), row.names = 1)
common_samples <- intersect(rownames(bac), rownames(met))
bac2 <- bac[common_samples, ]
met2 <- met[common_samples, ]
cor_mat <- cor(bac2, met2, method="spearman")
pheatmap(cor_mat,
color = colorRampPalette(c("blue","white","red"))(100))
# ==============================================================================
# FINAL FIGURE 1
# ==============================================================================
final_fig1 <- (p1A | p1C) /
(p1D | p1E) /
(p1G | p1H)
ggsave(file.path(output_dir, "Figure1_FINAL.pdf"),
final_fig1,
width = 16,
height = 20)
