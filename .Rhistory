# 注意：从 input_dir 读取
met <- read.delim(file.path(input_dir, "metabolism_sig647.txt"), row.names = 1, check.names = FALSE)
group_met <- factor(ifelse(grepl("^Control", rownames(met)), "Control", "SynCom"), levels = c("Control", "SynCom"))
met_stats <- data.frame(
metabolite = colnames(met),
mean_Control = colMeans(met[group_met == "Control", ], na.rm = TRUE),
mean_SynCom = colMeans(met[group_met == "SynCom", ], na.rm = TRUE)
) %>%
mutate(
log2FC = log2((mean_SynCom + 1e-10) / (mean_Control + 1e-10)),
P_value = apply(met, 2, function(x) t.test(x[group_met == "Control"], x[group_met == "SynCom"])$p.value),
neg_log10_p = -log10(P_value),
regulation = case_when(
P_value < 0.05 & log2FC > 1 ~ "Up",
P_value < 0.05 & log2FC < -1 ~ "Down",
TRUE ~ "Not significant"
)
)
sig_top20 <- met_stats %>% filter(regulation != "Not significant") %>% arrange(desc(abs(log2FC))) %>% head(20)
TOP20_SIG_METABOLITES <- sig_top20$metabolite
write.csv(sig_top20, "Top20_Significant_Metabolites.csv", row.names = FALSE)
met_stats$is_top20 <- met_stats$metabolite %in% TOP20_SIG_METABOLITES
# 火山图
volcano_plot <- ggplot(met_stats, aes(x=log2FC, y=neg_log10_p, color=regulation)) +
geom_point(alpha=0.5, size=1.5) +
scale_color_manual(values=c("Up"="#D73027", "Down"="#2E6B8A", "Not significant"="grey70")) +
geom_vline(xintercept=c(-1, 1), linetype="dashed", color="grey40") +
geom_hline(yintercept=-log10(0.05), linetype="dashed", color="grey40") +
geom_text_repel(data=sig_top20, aes(label=metabolite), size=3, color="black", max.overlaps=20) +
labs(title="Volcano Plot: SynCom vs Control", x=expression(log[2]~"(Fold Change)"), y=expression(-log[10]~"(P-value)")) +
theme_minimal(base_size=12) + theme(plot.title=element_text(hjust=0.5, face="bold"), legend.position="bottom")
ggsave("Volcano_Plot.pdf", volcano_plot, width=10, height=7)
# 条形图
bar_data <- sig_top20 %>% mutate(metabolite = factor(metabolite, levels=rev(metabolite)))
bar_plot <- ggplot(bar_data, aes(x=log2FC, y=metabolite, fill=regulation)) +
geom_bar(stat="identity", width=0.8) +
scale_fill_manual(values=c("Up"="#D73027", "Down"="#2E6B8A")) +
geom_vline(xintercept=0, color="black") +
labs(title="Top20 Significant Metabolites", x=expression(log[2]~"(Fold Change)"), y="") +
theme_minimal(base_size=11) + theme(plot.title=element_text(hjust=0.5, face="bold"), legend.position="bottom")
ggsave("Top20_Significant_Metabolites_Barplot.pdf", bar_plot, width=10, height=8)
# 热图函数
make_heatmap <- function(data, data_name, met_data, met_list, output_prefix) {
common_samples <- intersect(rownames(data), rownames(met_data))
if(length(common_samples) < 3) return(NULL)
data_c <- data[common_samples, , drop=FALSE]
met_c <- met_data[common_samples, met_list, drop=FALSE]
cor_matrix <- cor(data_c, met_c, method="spearman", use="pairwise.complete.obs")
p_matrix <- apply(met_c, 2, function(m) apply(data_c, 2, function(d) cor.test(d, m, method="spearman")$p.value))
sig_matrix <- matrix("", nrow=nrow(p_matrix), ncol=ncol(p_matrix), dimnames=dimnames(p_matrix))
sig_matrix[p_matrix < 0.001] <- "***"
sig_matrix[p_matrix < 0.01 & p_matrix >= 0.001] <- "**"
sig_matrix[p_matrix < 0.05 & p_matrix >= 0.01] <- "*"
sig_matrix[p_matrix < 0.1 & p_matrix >= 0.05] <- "."
cor_matrix[is.na(cor_matrix)] <- 0
pdf(paste0(output_prefix, ".pdf"), width=max(8, length(met_list)*0.3), height=max(6, ncol(data_c)*0.4))
pheatmap(cor_matrix, color=colorRampPalette(c("blue", "white", "red"))(100), breaks=seq(-1, 1, length.out=101),
main=paste(data_name, "Correlation"), display_numbers=sig_matrix,
fontsize_row=9, fontsize_col=7, angle_col=45, number_color="black", fontsize_number=6)
dev.off()
write.csv(cor_matrix, paste0("Correlation_", output_prefix, ".csv"))
write.csv(p_matrix, paste0("Pvalue_", output_prefix, ".csv"))
}
# 注意：从 input_dir 读取
bac <- read.delim(file.path(input_dir, "rootbac_genus_sig20.txt"), row.names=1, check.names=FALSE)
property <- read.delim(file.path(input_dir, "property.txt"), row.names=1, check.names=FALSE)
growth <- read.delim(file.path(input_dir, "growth.txt"), row.names=1, check.names=FALSE)
make_heatmap(bac, "Bacteria", met, TOP20_SIG_METABOLITES, "Heatmap_Bacteria_vs_Top20SigMetabolites")
make_heatmap(property, "Soil Properties", met, TOP20_SIG_METABOLITES, "Heatmap_Properties_vs_Top20SigMetabolites")
make_heatmap(growth, "Growth Traits", met, TOP20_SIG_METABOLITES, "Heatmap_Growth_vs_Top20SigMetabolites")
make_heatmap(property, "Soil Properties", bac, colnames(bac), "Heatmap_Properties_vs_Bacteria")
make_heatmap(growth, "Growth Traits", bac, colnames(bac), "Heatmap_Growth_vs_Bacteria")
write.csv(met_stats, "Metabolite_Diff_Results.csv", row.names=FALSE)
cat("\n========== 所有分析完美完成！ ==========\n")
cat("所有数据均从:", input_dir, "读取\n")
cat("所有图表均存入:", output_dir, "\n")
