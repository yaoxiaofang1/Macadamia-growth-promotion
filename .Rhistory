df$Group <- ifelse(grepl("Control", df$Sample), "Control", "SynCom")
df_long <- df %>%
pivot_longer(-c(Sample, Group),
names_to = "Key",
values_to = "Value") %>%
mutate(
Type = substr(Key,1,1),
Day = gsub("[A-Z]", "", Key)
)
